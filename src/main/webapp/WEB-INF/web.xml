<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="https://jakarta.ee/xml/ns/jakartaee" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd" id="WebApp_ID" version="5.0">
  <display-name>JEE2</display-name>
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
    <welcome-file>login.html</welcome-file>
    <welcome-file>index.htm</welcome-file>
    <welcome-file>index.xhtml</welcome-file>
    <welcome-file>default.html</welcome-file>
    <welcome-file>default.jsp</welcome-file>
    <welcome-file>default.htm</welcome-file>
    <welcome-file>default.xhtml</welcome-file>
     </welcome-file-list>
    
    
<servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>com.tap.loginServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/LoginServlet</url-pattern>
</servlet-mapping>
 
  <servlet>
    <servlet-name>RestaurantServlet</servlet-name>
    <servlet-class>com.tap.RestaurantServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>RestaurantServlet</servlet-name>
    <url-pattern>/restaurants</url-pattern>
</servlet-mapping>
  
  <servlet>
    <servlet-name>MenuServlet</servlet-name>
    <servlet-class>com.tap.MenuServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>MenuServlet</servlet-name>
    <url-pattern>/MenuServlet</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>AddToCartServlet</servlet-name>
    <servlet-class>com.tap.AddToCartServlet</servlet-class>
</servlet>


  
  
  
  <servlet-mapping>
  <servlet-name>callServlet</servlet-name>
  <url-pattern>/RegisterServlet</url-pattern>
  </servlet-mapping>
  
  
  <servlet>
  <servlet-name>callServlet</servlet-name>
  <servlet-class>com.tap.RegisterServlet</servlet-class>
  </servlet>
</web-app>